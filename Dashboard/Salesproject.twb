          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Year' datatype='integer' default-format='n0;-0' name='[Parámetro 1]' param-domain-type='list' role='measure' type='quantitative' value='2023'>
              <calculation class='tableau' formula='2023' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1usaflp05rs750141jv3z0yhu4k8'>
            <column caption='PY Sales' datatype='real' default-format='n&quot;$&quot;#,##0,K;-&quot;$&quot;#,##0,K' name='[CY sales (copia)_0924144758652929]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR ([Order Date]) = [Parameters].[Parámetro 1]-1 THEN [Sales]&#13;&#10;END' />
            </column>
            <column caption='CY Sales' datatype='real' default-format='n&quot;$&quot;#,##0,K;-&quot;$&quot;#,##0,K' name='[Calculation_0924144758165504]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR ([Order Date]) = [Parameters].[Parámetro 1] THEN [Sales]&#13;&#10;END' />
            </column>
            <column caption='Order Date (Year)' datatype='integer' name='[Calculation_0924144759066626]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='YEAR ([Order Date])' />
            </column>
            <column caption='% Diff Sales' datatype='real' default-format='p0.0%' name='[Calculation_0924144760680451]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_0924144758165504])-SUM([CY sales (copia)_0924144758652929]))/SUM([CY sales (copia)_0924144758652929])' />
            </column>
            <column aggregation='Sum' caption='Current Year' datatype='integer' default-format='n0;-0' name='[Calculation_0924144771981319]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[Parameters].[Parámetro 1]' />
            </column>
            <column aggregation='Sum' caption='Previous Year' datatype='integer' default-format='n0;-0' name='[Calculation_0924144772145160]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[Parameters].[Parámetro 1]-1' />
            </column>
            <column caption='CY Profit' datatype='real' default-format='n&quot;$&quot;#,##0,K;-&quot;$&quot;#,##0,K' name='[Calculation_1171260200882176]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_0924144759066626]=[Parameters].[Parámetro 1] THEN [Profit]&#13;&#10;END' />
            </column>
            <column caption='PY Profit' datatype='real' default-format='n&quot;$&quot;#,##0,K;-&quot;$&quot;#,##0,K' name='[Calculation_1171260201127937]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_0924144759066626] = [Parameters].[Parámetro 1]-1 THEN [Profit]&#13;&#10;END' />
            </column>
            <column caption='% Diff Profit' datatype='real' default-format='p0.0%' name='[Calculation_1171260201365506]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_1171260200882176])-SUM([Calculation_1171260201127937]))/SUM([Calculation_1171260201127937])' />
            </column>
            <column caption='Min/Max Profit' datatype='real' default-format='n#,##0,K;-#,##0,K' name='[Calculation_1171260201799683]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([Calculation_1171260200882176])=WINDOW_MAX(SUM([Calculation_1171260200882176]))&#13;&#10;THEN SUM([Calculation_1171260200882176])&#13;&#10;ELSEIF SUM([Calculation_1171260200882176])=WINDOW_MIN(SUM([Calculation_1171260200882176]))&#13;&#10;THEN SUM([Calculation_1171260200882176])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
